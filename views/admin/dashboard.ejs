<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= title %> | Admin</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Fredoka+One&family=Nunito:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="/css/style.css" />
  <style>
    .file-input-wrap{display:flex;flex-direction:column;gap:6px}
    .file-input-wrap input[type="file"]{padding:10px 14px;border:2px dashed rgba(180,140,230,0.5);border-radius:14px;background:#f9f6ff;font-family:var(--font-body);font-size:.88rem;color:#5c3a9e;cursor:pointer;transition:border-color .2s}
    .file-input-wrap input[type="file"]:hover{border-color:var(--lavender-dark)}
    .file-label{font-weight:700;font-size:.85rem;color:#5c3a9e}
    .file-hint{font-size:.75rem;color:#a08cc8;font-style:italic}
    .preview-row{display:flex;gap:8px;flex-wrap:wrap;margin-top:8px}
    .preview-thumb{width:80px;height:60px;object-fit:cover;border-radius:10px;border:2px solid rgba(180,140,230,0.25)}
    .hero-photo-current{width:100%;max-height:220px;object-fit:cover;border-radius:16px;margin-bottom:12px;box-shadow:0 4px 16px rgba(140,100,200,0.15)}
    .msg-success{background:var(--green-light);color:#2b6b3a;padding:10px 18px;border-radius:var(--radius-pill);font-weight:700;font-size:.88rem;display:inline-block;margin-bottom:16px}
    .or-divider{display:flex;align-items:center;gap:12px;color:#a08cc8;font-size:.8rem;font-weight:700;margin:10px 0}
    .or-divider::before,.or-divider::after{content:'';flex:1;height:1px;background:rgba(160,140,200,0.25)}
    .admin-edit-toggle{padding:8px 10px;border:1px solid rgba(180,140,230,0.25);border-radius:999px;background:#f9f6ff;color:#5c3a9e;font-weight:700;cursor:pointer}
    .admin-edit-form{display:none;margin-top:10px;padding:12px;border:1px solid rgba(180,140,230,0.2);border-radius:14px;background:#fcfaff}
  </style>
</head>
<body class="admin-body">
<div class="admin-wrapper">

  <!-- SIDEBAR -->
  <nav class="admin-sidebar">
    <div class="admin-logo"><span>🦉</span><span>Admin Panel</span></div>
    <ul class="admin-nav">
      <li><a href="/admin"            class="admin-nav-item <%= section==='overview'    ? 'active':'' %>">📊 Resumen</a></li>
      <li><a href="/admin/fotos"      class="admin-nav-item <%= section==='fotos'       ? 'active':'' %>">📸 Fotos</a></li>
      <li><a href="/admin/juegos"     class="admin-nav-item <%= section==='juegos'      ? 'active':'' %>">🎮 Juegos</a></li>
      <li><a href="/admin/aprendemos" class="admin-nav-item <%= section==='aprendemos'  ? 'active':'' %>">📚 Aprendemos</a></li>
      <li><a href="/admin/tareas"     class="admin-nav-item <%= section==='tareas'      ? 'active':'' %>">🗒️ Tareas</a></li>
      <li><a href="/admin/escritor"   class="admin-nav-item <%= section==='escritor'    ? 'active':'' %>">✍️ Escritor</a></li>
      <li><a href="/admin/aprendizaje" class="admin-nav-item <%= section==='aprendizaje'? 'active':'' %>">🌟 Aprendizaje</a></li>
    </ul>
    <div class="admin-sidebar-footer">
      <a href="/" class="admin-nav-item">🏠 Ver sitio</a>
      <a href="/admin/logout" class="admin-nav-item logout-btn">🚪 Salir</a>
    </div>
  </nav>

  <!-- MAIN -->
  <main class="admin-main">
    <div class="admin-topbar">
      <h1 class="admin-page-title"><%= title %></h1>
      <% if (msg) { %><div class="msg-success">✅ ¡Guardado exitosamente!</div><% } %>
    </div>

    <!-- ══════ OVERVIEW ══════════════════════════ -->
    <% if (section === 'overview') { %>
      <div class="admin-stats-grid">
        <div class="admin-stat-card clay-card"><div class="admin-stat-icon">📸</div><div class="admin-stat-num"><%= stats.photos %></div><div class="admin-stat-label">Fotos</div><a href="/admin/fotos" class="btn btn-sm">Gestionar</a></div>
        <div class="admin-stat-card clay-card"><div class="admin-stat-icon">🎮</div><div class="admin-stat-num"><%= stats.games %></div><div class="admin-stat-label">Juegos</div><a href="/admin/juegos" class="btn btn-sm">Gestionar</a></div>
        <div class="admin-stat-card clay-card"><div class="admin-stat-icon">📚</div><div class="admin-stat-num"><%= stats.lessons %></div><div class="admin-stat-label">Lecciones</div><a href="/admin/aprendemos" class="btn btn-sm">Gestionar</a></div>
        <div class="admin-stat-card clay-card"><div class="admin-stat-icon">🗒️</div><div class="admin-stat-num"><%= stats.tasks %></div><div class="admin-stat-label">Tareas</div><a href="/admin/tareas" class="btn btn-sm">Gestionar</a></div>
        <div class="admin-stat-card clay-card"><div class="admin-stat-icon">✍️</div><div class="admin-stat-num"><%= stats.works %></div><div class="admin-stat-label">Producciones</div><a href="/admin/escritor" class="btn btn-sm">Gestionar</a></div>
        <div class="admin-stat-card clay-card"><div class="admin-stat-icon">🌟</div><div class="admin-stat-num"><%= stats.learnings %></div><div class="admin-stat-label">Aprendizajes</div><a href="/admin/aprendizaje" class="btn btn-sm">Gestionar</a></div>
      </div>

      <!-- Foto principal del inicio -->
      <div class="admin-form-card clay-card">
        <h2 class="admin-form-title">🖼️ Foto Principal del Inicio</h2>
        <% if (settings && settings.heroPhotoUrl) { %><img src="<%= settings.heroPhotoUrl %>" class="hero-photo-current" /><% } %>
        <form action="/admin/hero-photo" method="POST" enctype="multipart/form-data" class="admin-form">
          <div class="form-group file-input-wrap">
            <label class="file-label">📂 Selecciona una foto desde tu computadora</label>
            <input type="file" name="heroPhoto" accept="image/*" />
            <span class="file-hint">Se sube a Cloudinary automáticamente. Máx 10 MB.</span>
          </div>
          <button type="submit" class="btn btn-primary">💾 Guardar foto</button>
        </form>
      </div>

      <!-- Desafío semanal -->
      <div class="admin-form-card clay-card">
        <h2 class="admin-form-title">⚡ Desafío Ortográfico Semanal</h2>
        <% if (challenge) { %><div class="current-challenge"><strong>Actual:</strong> <%= challenge.text %></div><% } %>
        <form action="/admin/challenge" method="POST" class="admin-form">
          <div class="form-group"><label>Texto del desafío *</label><textarea name="text" class="form-input" rows="3" required><%= challenge ? challenge.text : '' %></textarea></div>
          <div class="form-group"><label>Pista (opcional)</label><input type="text" name="hint" class="form-input" value="<%= challenge ? challenge.hint||'' : '' %>" /></div>
          <button type="submit" class="btn btn-primary">💾 Guardar Desafío</button>
        </form>
      </div>

    <!-- ══════ FOTOS ════════════════════════════ -->
    <% } else if (section === 'fotos') { %>
      <div class="admin-form-card clay-card">
        <h2 class="admin-form-title">➕ Agregar Fotos a la Galería</h2>
        <form action="/admin/fotos" method="POST" enctype="multipart/form-data" class="admin-form">
          <div class="form-row">
            <div class="form-group"><label>Título *</label><input type="text" name="title" class="form-input" required placeholder="Ej: Día del libro" /></div>
            <div class="form-group"><label>Categoría</label>
              <select name="category" class="form-input"><option>Actividades</option><option>Eventos</option><option>Este mes</option><option>Otros</option></select>
            </div>
          </div>

          <div class="form-group file-input-wrap">
            <label class="file-label">📂 Selecciona hasta 5 fotos desde tu computadora</label>
            <input type="file" name="imageFiles" accept="image/*" multiple onchange="previewMulti(this)" />
            <span class="file-hint">Se suben a Cloudinary. Formatos: JPG, PNG, WEBP. Máx 10 MB cada una.</span>
            <div class="preview-row" id="multiPreview"></div>
          </div>

          <div class="or-divider">ó pega una URL externa</div>
          <div class="form-group"><input type="url" name="imageUrl" class="form-input" placeholder="https://ejemplo.com/foto.jpg (opcional)" /></div>

          <div class="form-row">
            <div class="form-group"><label>Fecha</label><input type="date" name="date" class="form-input" /></div>
            <div class="form-group"><label>Descripción</label><input type="text" name="description" class="form-input" placeholder="Breve descripción..." /></div>
          </div>
          <button type="submit" class="btn btn-primary">📸 Agregar Fotos</button>
        </form>
      </div>

      <div class="admin-table-card clay-card">
        <h2 class="admin-form-title">Fotos existentes (<%= photos.length %>)</h2>
        <% if (!photos.length) { %><p class="admin-empty">No hay fotos aún.</p><% } else { %>
          <div class="admin-cards-list"><% photos.forEach(p => { %>
            <div class="admin-item">
              <% if (p.imageUrl) { %><img src="<%= p.imageUrl %>" class="admin-thumb" /><% } else { %><span class="admin-emoji">📸</span><% } %>
              <div class="admin-item-info">
                <strong><%= p.title %></strong>
                <span class="tag"><%= p.category %></span>
                <% const cnt = (p.allImages||[]).length; if(cnt>1){ %><span class="tag tag-new">🖼️ <%= cnt %> fotos</span><% } %>
              </div>
              <form action="/admin/fotos/<%= p._id %>?_method=DELETE" method="POST"><button type="submit" class="btn btn-danger" onclick="return confirm('¿Eliminar?')">🗑️</button></form>
            </div>
          <% }); %></div>
        <% } %>
      </div>

    <!-- ══════ JUEGOS ═══════════════════════════ -->
    <% } else if (section === 'juegos') { %>
      <div class="admin-form-card clay-card">
        <h2 class="admin-form-title">➕ Agregar Juego</h2>
        <form action="/admin/juegos" method="POST" class="admin-form">
          <div class="form-row"><div class="form-group"><label>Nombre *</label><input type="text" name="name" class="form-input" required /></div><div class="form-group"><label>Emoji</label><input type="text" name="imageEmoji" class="form-input" value="🎮" maxlength="4" /></div></div>
          <div class="form-group"><label>Descripción *</label><textarea name="description" class="form-input" rows="2" required></textarea></div>
          <div class="form-row"><div class="form-group"><label>Dificultad (1-5)</label><input type="number" name="difficulty" class="form-input" min="1" max="5" value="3" /></div><div class="form-group"><label>URL externa</label><input type="url" name="externalUrl" class="form-input" placeholder="https://..." /></div></div>
          <button type="submit" class="btn btn-primary">🎮 Agregar</button>
        </form>
      </div>
      <div class="admin-table-card clay-card"><h2 class="admin-form-title">Juegos (<%= games.length %>)</h2>
        <% if(!games.length){%><p class="admin-empty">No hay juegos.</p><%}else{%><div class="admin-cards-list"><%games.forEach(g=>{%>
          <div class="admin-item"><span class="admin-emoji"><%= g.imageEmoji %></span><div class="admin-item-info"><strong><%= g.name %></strong></div>
          <form action="/admin/juegos/<%= g._id %>?_method=DELETE" method="POST"><button type="submit" class="btn btn-danger" onclick="return confirm('¿Eliminar?')">🗑️</button></form></div>
        <%});%></div><%}%>
      </div>

    <!-- ══════ APRENDEMOS ═══════════════════════ -->
    <% } else if (section === 'aprendemos') { %>
      <div class="admin-form-card clay-card">
        <h2 class="admin-form-title">➕ Agregar Publicación</h2>
        <form action="/admin/aprendemos" method="POST" enctype="multipart/form-data" class="admin-form">
          <div class="form-row"><div class="form-group"><label>Tema *</label><input type="text" name="topic" class="form-input" required /></div>
          <div class="form-group"><label>Categoría</label><select name="category" class="form-input"><option>Lectura</option><option>Escritura</option><option>Ortografía</option><option>Expresión</option><option>Otros</option></select></div></div>
          <div class="form-group"><label>Descripción *</label><textarea name="description" class="form-input" rows="3" required></textarea></div>
          <div class="form-row"><div class="form-group"><label>Fecha</label><input type="date" name="date" class="form-input" /></div>
          <div class="form-group file-input-wrap"><label class="file-label">📂 Imagen</label><input type="file" name="imageFile" accept="image/*" /></div></div>
          <div class="form-group form-check"><input type="checkbox" id="isNewPost" name="isNewPost" class="form-checkbox" /><label for="isNewPost">🆕 Marcar como nuevo</label></div>
          <button type="submit" class="btn btn-primary">📚 Agregar</button>
        </form>
      </div>
      <div class="admin-table-card clay-card"><h2 class="admin-form-title">Publicaciones (<%= lessons.length %>)</h2>
        <% if(!lessons.length){%><p class="admin-empty">Vacío.</p><%}else{%><div class="admin-cards-list"><%lessons.forEach(l=>{%>
          <div class="admin-item"><span class="admin-emoji">📚</span><div class="admin-item-info"><strong><%= l.topic %></strong><span class="tag"><%= l.category %></span><% if(l.isNewPost){%><span class="tag tag-new">🆕</span><%}%></div>
          <form action="/admin/aprendemos/<%= l._id %>?_method=DELETE" method="POST"><button type="submit" class="btn btn-danger" onclick="return confirm('¿Eliminar?')">🗑️</button></form></div>
        <%});%></div><%}%>
      </div>

    <!-- ══════ TAREAS ═══════════════════════════ -->
    <% } else if (section === 'tareas') { %>
      <div class="admin-form-card clay-card">
        <h2 class="admin-form-title">➕ Agregar Tarea</h2>
        <form action="/admin/tareas" method="POST" class="admin-form">
          <div class="form-row"><div class="form-group"><label>Título *</label><input type="text" name="title" class="form-input" required /></div><div class="form-group"><label>Materia</label><input type="text" name="subject" class="form-input" value="Español" /></div></div>
          <div class="form-group"><label>Descripción *</label><textarea name="description" class="form-input" rows="3" required></textarea></div>
          <div class="form-row"><div class="form-group"><label>Fecha de entrega *</label><input type="date" name="dueDate" class="form-input" required /></div>
          <div class="form-group"><label>Estado</label><select name="status" class="form-input"><option value="Pendiente">🟡 Pendiente</option><option value="En proceso">🔵 En proceso</option><option value="Completada">✅ Completada</option></select></div></div>
          <button type="submit" class="btn btn-primary">🗒️ Agregar</button>
        </form>
      </div>
      <div class="admin-table-card clay-card"><h2 class="admin-form-title">Tareas (<%= tasks.length %>)</h2>
        <% if(!tasks.length){%><p class="admin-empty">Vacío.</p><%}else{%><div class="admin-cards-list"><%tasks.forEach(t=>{%>
          <div class="admin-item"><span class="admin-emoji">🗒️</span><div class="admin-item-info"><strong><%= t.title %></strong><span class="tag"><%= t.status %></span><small>Vence: <%= new Date(t.dueDate).toLocaleDateString('es-MX') %></small></div>
          <div class="admin-item-actions">
            <form action="/admin/tareas/<%= t._id %>?_method=PUT" method="POST" style="display:inline-flex;gap:4px"><select name="status" class="form-input form-input-sm"><option value="Pendiente" <%=t.status==='Pendiente'?'selected':''%>>🟡</option><option value="En proceso" <%=t.status==='En proceso'?'selected':''%>>🔵</option><option value="Completada" <%=t.status==='Completada'?'selected':''%>>✅</option></select><button type="submit" class="btn btn-sm btn-success">✓</button></form>
            <button type="button" class="admin-edit-toggle" onclick="toggleTaskEdit('<%= t._id %>')">✏️ Editar</button>
            <form action="/admin/tareas/<%= t._id %>?_method=DELETE" method="POST"><button type="submit" class="btn btn-danger" onclick="return confirm('¿Eliminar?')">🗑️</button></form>
          </div>
          <div id="edit-task-<%= t._id %>" class="admin-edit-form">
            <form action="/admin/tareas/<%= t._id %>?_method=PUT" method="POST" class="admin-form">
              <div class="form-row">
                <div class="form-group"><label>Título</label><input type="text" name="title" class="form-input" value="<%= t.title %>" required /></div>
                <div class="form-group"><label>Materia</label><input type="text" name="subject" class="form-input" value="<%= t.subject %>" /></div>
              </div>
              <div class="form-group"><label>Descripción</label><textarea name="description" class="form-input" rows="3" required><%= t.description %></textarea></div>
              <div class="form-row">
                <div class="form-group"><label>Fecha de entrega</label><input type="date" name="dueDate" class="form-input" value="<%= new Date(t.dueDate).toISOString().split('T')[0] %>" required /></div>
                <div class="form-group"><label>Estado</label><select name="status" class="form-input"><option value="Pendiente" <%=t.status==='Pendiente'?'selected':''%>>🟡 Pendiente</option><option value="En proceso" <%=t.status==='En proceso'?'selected':''%>>🔵 En proceso</option><option value="Completada" <%=t.status==='Completada'?'selected':''%>>✅ Completada</option></select></div>
              </div>
              <button type="submit" class="btn btn-primary">💾 Guardar cambios</button>
            </form>
          </div>
        </div>
        <%});%></div><%}%>
      </div>

    <!-- ══════ ESCRITOR ═════════════════════════ -->
    <% } else if (section === 'escritor') { %>
      <div class="admin-form-card clay-card">
        <h2 class="admin-form-title">➕ Agregar Producción Escrita</h2>
        <form action="/admin/escritor" method="POST" enctype="multipart/form-data" class="admin-form">
          <div class="form-row"><div class="form-group"><label>Nombre del estudiante *</label><input type="text" name="studentName" class="form-input" required placeholder="Ej: Sofía" /></div>
          <div class="form-group"><label>Título *</label><input type="text" name="title" class="form-input" required placeholder="Ej: El gato mágico" /></div></div>
          <div class="form-group"><label>Texto *</label><textarea name="content" class="form-input" rows="6" required></textarea></div>
          <div class="form-group file-input-wrap"><label class="file-label">📂 Ilustración (opcional)</label><input type="file" name="imageFile" accept="image/*" /><span class="file-hint">Se sube a Cloudinary. Máx 10 MB.</span></div>
          <button type="submit" class="btn btn-primary">✍️ Publicar</button>
        </form>
      </div>
      <div class="admin-table-card clay-card"><h2 class="admin-form-title">Producciones (<%= works.length %>)</h2>
        <% if(!works.length){%><p class="admin-empty">Vacío.</p><%}else{%><div class="admin-cards-list"><%works.forEach(w=>{%>
          <div class="admin-item"><span class="admin-emoji">✍️</span><div class="admin-item-info"><strong><%= w.title %></strong><span class="tag"><%= w.studentName %></span><small><%= w.likes %> ⭐</small></div>
          <form action="/admin/escritor/<%= w._id %>?_method=DELETE" method="POST"><button type="submit" class="btn btn-danger" onclick="return confirm('¿Eliminar?')">🗑️</button></form></div>
        <%});%></div><%}%>
      </div>

    <!-- ══════ APRENDIZAJE ══════════════════════ -->
    <% } else if (section === 'aprendizaje') { %>
      <div class="admin-form-card clay-card">
        <h2 class="admin-form-title">➕ Agregar Recurso</h2>
        <form action="/admin/aprendizaje" method="POST" class="admin-form">
          <div class="form-row"><div class="form-group"><label>Título *</label><input type="text" name="title" class="form-input" required /></div>
          <div class="form-group"><label>Categoría</label><select name="category" class="form-input"><option>Reglas</option><option>Trucos</option><option>Actividades</option><option>Desafíos</option></select></div></div>
          <div class="form-group"><label>Emoji</label><input type="text" name="emoji" class="form-input" value="📖" maxlength="4" style="max-width:100px" /></div>
          <div class="form-group"><label>Contenido *</label><textarea name="content" class="form-input" rows="4" required></textarea></div>
          <button type="submit" class="btn btn-primary">🌟 Agregar</button>
        </form>
      </div>
      <div class="admin-table-card clay-card"><h2 class="admin-form-title">Recursos (<%= learnings.length %>)</h2>
        <% if(!learnings.length){%><p class="admin-empty">Vacío.</p><%}else{%><div class="admin-cards-list"><%learnings.forEach(l=>{%>
          <div class="admin-item"><span class="admin-emoji"><%= l.emoji %></span><div class="admin-item-info"><strong><%= l.title %></strong><span class="tag"><%= l.category %></span></div>
          <form action="/admin/aprendizaje/<%= l._id %>?_method=DELETE" method="POST"><button type="submit" class="btn btn-danger" onclick="return confirm('¿Eliminar?')">🗑️</button></form></div>
        <%});%></div><%}%>
      </div>
    <% } %>
  </main>
</div>
<script>
function previewMulti(input){
  const row=document.getElementById('multiPreview');
  row.innerHTML='';
  if(!input.files)return;
  [...input.files].slice(0,5).forEach(file=>{
    const r=new FileReader();
    r.onload=e=>{const img=document.createElement('img');img.src=e.target.result;img.className='preview-thumb';row.appendChild(img);};
    r.readAsDataURL(file);
  });
}

function toggleTaskEdit(taskId){
  const form=document.getElementById(`edit-task-${taskId}`);
  if(!form)return;
  form.style.display = form.style.display === 'block' ? 'none' : 'block';
}
</script>
</body>
</html>
